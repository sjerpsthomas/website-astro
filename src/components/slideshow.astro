---
import {Image} from 'astro:assets';
import type { ImageMetadata } from 'astro';

type Props = {
  speed: number;
}
const { speed } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/slideshow/*.{jpeg,jpg,png,webp}',
  { eager: true }
);

const slides = Object.values(images).map(img =>
  img.default
);
---

<div class="embla select-none" data-speed={speed}>
  <div class="embla__viewport">
    <div class="embla__container">
      {slides.map((slide, index) =>
        <div class="embla__slide">
          <Image
            class="embla__slide__content"
            src={slide}
            alt={"YISKA"}
          />
        </div>
      )}
    </div>
  </div>
</div>

<script>
  import EmblaCarousel from 'embla-carousel';
  import AutoScroll from 'embla-carousel-auto-scroll'

  const OPTIONS = { loop: true, dragFree: true };
  const emblaNodes = document.querySelectorAll<HTMLElement>('.embla');

  emblaNodes.forEach((emblaNode) => {
    const scrollSpeed = Number(emblaNode.dataset.speed) || 1;
    const viewportNode = emblaNode.querySelector('.embla__viewport') as HTMLElement;

    if (viewportNode) {
      EmblaCarousel(viewportNode, OPTIONS, [AutoScroll({ speed: scrollSpeed })]);
    }
  });
</script>