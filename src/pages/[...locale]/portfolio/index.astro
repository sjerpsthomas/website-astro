---
import PageLayout from "@layouts/page-layout.astro";
import {DEFAULT_LOCALE, type Locale, LOCALES} from "@lib/locale.ts";
import PortfolioSection from "@components/portfolio-section.astro";
import bgGroover from '@assets/portfolio_bg_groover.jpg';
import bgMusic from '@assets/portfolio_bg_music.jpg';
import bgProgramming from '@assets/portfolio_bg_programming.jpg';


export function getStaticPaths() {
  return [...LOCALES.map(it => ({ params: { locale: it } })), { params: { locale: undefined } }];
}

const locale = (Astro.params.locale ?? DEFAULT_LOCALE) as Locale;
---

<PageLayout locale={locale}>
  <PortfolioSection locale={locale} background={bgProgramming} title="...programmeren:" speed={0.8} tags={["solo", "programming", "programmeren"]}/>
  <PortfolioSection locale={locale} background={bgGroover} title="...m'n studentenvereniging:" speed={1.0} tags={["association", "vereniging"]}/>
  <PortfolioSection locale={locale} background={bgMusic} title="...muziek:" speed={1.2} tags={["music", "muziek"]}/>
</PageLayout>

<style>
  a {
    font-family: var(--font-thomas-title), serif;
    font-weight: var(--font-weight-bold);
    padding-bottom: 0.6rem;
    text-decoration-line: none;
    color: white;
  }
</style>