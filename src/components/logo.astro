---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

const logoFiles = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/logo/*.{png,webp,jpg}',
  { eager: true }
);

const logos = Object.values(logoFiles)
  .map((img) => img.default)
  .toSorted((a, b) => a.src.localeCompare(b.src));
---

<div
  id="logo-container"
  class="relative xl:w-[45%] md:w-[60%] w-[80%] aspect-[10/4] hover:scale-105 transition-transform overflow-hidden"
>
  {logos.map((logo, index) => 
    <Image
      src={logo}
      alt="YISKA Logo"
      loading="eager"
      decoding="sync"
      class={`absolute inset-0 w-full h-full object-contain pointer-events-none transition-opacity duration-0 ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
    />
  )}
</div>

<script>
  const container = document.querySelector('#logo-container');
  // Target only the images inside our specific container
  const images = container?.querySelectorAll('img');

  if (container && images && images.length > 0) {
    let currentIndex = 0;
    const total = images.length;

    container.addEventListener('mouseenter', () => {
      // 1. Hide current by dropping opacity
      images[currentIndex].classList.replace('opacity-100', 'opacity-0');

      // 2. Increment index
      currentIndex = (currentIndex + 1) % total;

      // 3. Show next by raising opacity
      images[currentIndex].classList.replace('opacity-0', 'opacity-100');
    });
  }
</script>