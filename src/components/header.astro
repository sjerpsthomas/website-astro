---
import {type Locale} from "@lib/locale";
import shirt from '@assets/shirt-2.png';
import {getDictKeys} from "@lib/utils";

type Props = {
  locale: Locale,
}
const { locale } = Astro.props;

const pages = {
  "": {
    nl: { title: "HOME", href: "", description: "Beschrijving voor 'home'." },
    en: { title: "HOME", href: "", description: "Description for 'home'." },
  },
  cv: {
    nl: { title: "CV", href: "cv", description: "Beschrijving voor 'cv'." },
    en: { title: "CV", href: "cv", description: "Description for 'cv'." },
  },
  portfolio: {
    nl: { title: "PORTFOLIO", href: "portfolio", description: "Beschrijving voor 'portfolio'." },
    en: { title: "PORTFOLIO", href: "portfolio", description: "Description for 'portfolio'." },
  },
}

const localeHref = locale === 'nl' ? '/' : `/en/`;
const otherLocaleHref = locale === 'nl' ? `/en/` : '/';

const currentPath = Astro.url.pathname;
const currentPage = ("/" + currentPath).split('/').at(-1)
console.log(currentPage);
---


<header class="flex flex-row items-center justify-center space-x-10 bg-gray-900 py-10 bg-center bg-cover" style={{ backgroundImage: `linear-gradient(to bottom, rgba(0,0,0,0.0),rgba(0,0,0,0.4)), url(${shirt.src})` }}>
  <a href={otherLocaleHref + currentPage} class="header-button flex flex-row items-center space-x-1 !px-5 !pb-2">
    <span class={locale == "nl" ? "font-bold !text-lg" : "font-light opacity-70 !text-sm"}>NL</span>
    <span class="font-light opacity-50 !text-sm">/</span>
    <span class={locale == "en" ? "font-bold !text-lg" : "font-light opacity-70 !text-sm"}>EN</span>
  </a>

  {getDictKeys(pages).map((pageName) => {
    const pageDict = pages[pageName];

    if (pageName == currentPage) {
      return (
        <div class="bg-black text-center rounded-3xl px-8 py-2 pb-3 shadow-xl">
          <h1 class="!text-6xl !mb-2 font-black">{pageDict[locale].title}</h1>
          <p>
            {pageDict[locale].description}
          </p>
        </div>
      );
    }

    return (
      <a href={localeHref + pageDict[locale].href} class="header-button">
        <span>{pageDict[locale].title}</span>
      </a>
    );
  })}
</header>


<style>
  @import '@styles/global.css';
  a {
    @apply bg-black text-center rounded-full px-10 py-2 pb-3 text-2xl font-bold !text-white !no-underline hover:scale-105 hover:shadow-md transition-all;
    font-family: var(--font-thomas-title), serif;
  }
</style>
