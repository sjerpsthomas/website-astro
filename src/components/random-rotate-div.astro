---
interface Props {
  class?: string;
  [key: string]: unknown;
}

const { class: className, ...rest } = Astro.props;
---

<div 
  class:list={[
    "random-rotate-container",
    "rounded-3xl transition-all duration-250 ease-in-out cursor-default",
    className
  ]}
  {...rest}
>
  <slot />
</div>

<style>
  .random-rotate-container {
    transform: rotate(0deg) scale(1);
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
  }

  .random-rotate-container:hover {
    transform: rotate(var(--rotate-deg, 0deg)) scale(1.05);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.15);
  }
</style>

<script>
const containers = document.querySelectorAll('.random-rotate-container');
const rotations = [-2, -1, 1, 2];

for (const container of containers) {
  container.addEventListener('mouseenter', () => {
    // eslint-disable-next-line sonarjs/pseudo-random
    const randomRotation = rotations[Math.floor(Math.random() * rotations.length)];
    (container as HTMLElement).style.setProperty('--rotate-deg', `${randomRotation}deg`);
  });

  container.addEventListener('mouseleave', () => {
    (container as HTMLElement).style.removeProperty('--rotate-deg');
  });
}
</script>