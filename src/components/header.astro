---
import LocaleToggle from "@/components/locale-toggle.astro";
import {type Locale} from "../lib/locale";

type Props = {
  locale: Locale,
}
const { locale } = Astro.props;

const sections = [
  { title: "CV", href: "cv" },
  { title: "Portfolio", href: "portfolio" },
]

// TODO: other pages have a different href
const localeHref = locale === 'nl' ? '/' : `/en/`;
const otherLocaleHref = locale === 'nl' ? `/en/` : '/';
---

<header class="w-fit mx-auto px-3 pt-1 pb-2 sticky top-2 z-10">
  <div class="flex flex-wrap justify-center rounded-3xl bg-[#00000088] backdrop-blur-lg select-none">
    {/* Language toggle */}
    <LocaleToggle currentLocale={locale} href={otherLocaleHref} />

    {/* Links */}
    {sections.map((section) => 
      <a
        href={`${localeHref}${section.href}`}
        class="navbar_item py-1 text-nowrap hover:scale-105 transition-transform w-[8rem] flex justify-center items-center text-center"
      >
        {section.title}
      </a>
    )}
  </div>
</header>
